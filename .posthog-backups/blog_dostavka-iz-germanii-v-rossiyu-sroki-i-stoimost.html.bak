    <script>
    async function submitForm(e) {
        e.preventDefault();
        const btn = e.target.querySelector('button');
        const result = document.getElementById('formResult');
        btn.textContent = 'Отправляем...'; btn.disabled = true;
        try {
            const res = await fetch('/api/contact', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    name: document.getElementById('f-name').value,
                    company: '',
                    contact: document.getElementById('f-contact').value,
                    message: document.getElementById('f-message').value + ' (из статьи: Доставка из Германии в Россию: сроки и стоимость)',
                })
            });
            if (res.ok) {
                result.style.color = '#22C55E';
                result.textContent = 'Отправлено! Ответим в течение часа.';
                e.target.reset();
            } else { throw new Error(); }
        } catch { result.style.color = '#EF4444'; result.textContent = 'Ошибка. Напишите на ceo@elpcargo.ru'; }
        btn.textContent = 'Запросить расчёт'; btn.disabled = false;
    }
    </script>
    
